{
  "name": "@sreeport/core",
  "version": "0.1.2",
  "description": "Core engine for Sreeport local development orchestration.",
  "type": "module",
  "author": "Sreejith Muralidharan <hello@sreejith.co.uk> (https://sreejith.co.uk)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreejithmuralidharan/sreeport.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "env-paths": "^3.0.0",
    "jiti": "^2.6.1",
    "zod": "^4.2.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/sreejithmuralidharan/sreeport/tree/main/packages/core#readme",
  "keywords": [
    "sreeport",
    "local-development",
    "dev-server",
    "ports",
    "localhost",
    "caddy",
    "orchestration"
  ],
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/sreejithmuralidharan/sreeport/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
