{
  "name": "@sreeport/next",
  "version": "0.1.2",
  "description": "Next.js integration helpers for Sreeport.",
  "type": "module",
  "author": "Sreejith Muralidharan <hello@sreejith.co.uk> (https://sreejith.co.uk)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreejithmuralidharan/sreeport.git",
    "directory": "packages/next"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sreeport/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/sreejithmuralidharan/sreeport/tree/main/packages/next#readme",
  "keywords": [
    "sreeport",
    "nextjs",
    "next-config",
    "local-development",
    "allowed-dev-origins",
    "localhost"
  ],
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/sreejithmuralidharan/sreeport/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
