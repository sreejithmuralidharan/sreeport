{
  "name": "@sreeport/cli",
  "version": "0.1.3",
  "description": "Command-line interface for Sreeport.",
  "type": "module",
  "author": "Sreejith Muralidharan <hello@sreejith.co.uk> (https://sreejith.co.uk)",
  "license": "MIT",
  "bin": {
    "sreeport": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreejithmuralidharan/sreeport.git",
    "directory": "packages/cli"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/fix-bin.mjs",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sreeport/core": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "homepage": "https://github.com/sreejithmuralidharan/sreeport/tree/main/packages/cli#readme",
  "keywords": [
    "sreeport",
    "cli",
    "local-development",
    "dev-server",
    "ports",
    "localhost",
    "caddy",
    "nextjs"
  ],
  "bugs": {
    "url": "https://github.com/sreejithmuralidharan/sreeport/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
