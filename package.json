{
  "name": "sreeport",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "A local development orchestrator with clean ports, local domains, browser routing, and a native macOS menu bar.",
  "author": "Sreejith Muralidharan <hello@sreejith.co.uk> (https://sreejith.co.uk)",
  "license": "MIT",
  "homepage": "https://github.com/sreejithmuralidharan/sreeport#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreejithmuralidharan/sreeport.git"
  },
  "bugs": {
    "url": "https://github.com/sreejithmuralidharan/sreeport/issues"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter @sreeport/mac build",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "build:mac": "pnpm --filter @sreeport/mac build",
    "package:mac": "node scripts/package-macos-app.mjs",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev": "pnpm --filter @sreeport/cli dev",
    "lint": "eslint .",
    "pack:dry": "pnpm -r --filter './packages/*' pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc -b packages/core packages/cli packages/next packages/mcp"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  }
}
